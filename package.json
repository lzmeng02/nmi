{
  "name": "nmi",
  "version": "0.1.0",
  "description": "Android AI UI testing framework powered by VLM + accessibility tree",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "example": "tsx --env-file=.env",
    "example:tap": "tsx --env-file=.env examples/simple-tap.ts",
    "example:excel": "tsx --env-file=.env examples/run-excel.ts"
  },
  "dependencies": {
    "openai": "^4.73.0",
    "xlsx": "^0.18.5",
    "fast-xml-parser": "^4.5.0",
    "js-yaml": "^4.1.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0",
    "@types/js-yaml": "^4.0.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
